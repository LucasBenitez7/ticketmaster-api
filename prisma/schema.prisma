generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma/client"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Event {
  id               String   @id @default(uuid())
  title            String
  description      String
  date             DateTime
  location         String
  price            Decimal  @db.Decimal(10, 2)
  totalTickets     Int
  availableTickets Int
  posterUrl        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("events")
}
